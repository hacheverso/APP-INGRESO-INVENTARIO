generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  sheetsUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  products Product[]
  sessions HistorySession[]
}

model Product {
  id        String   @id @default(cuid())
  upc       String
  sku       String
  name      String
  image     String?
  category  String   @default("")
  lastCost  Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String   @default("")
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([upc, userId])
}

model HistorySession {
  id         String   @id @default(uuid())
  date       String
  batchName  String?
  provider   String?
  totalItems Int
  totalCop   Float
  records    HistoryRecord[]
  createdAt  DateTime @default(now())

  holdedInvoiceId  String?
  holdedInvoiceNum String?

  userId String   @default("")
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HistoryRecord {
  id        String   @id @default(uuid())
  sessionId String
  session   HistorySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  fecha     String
  cantidad  Int
  seriales  String
  tipo      String   @default("MASIVO")
  upc       String
  sku       String
  nombre    String
  imagen    String   @default("")
  costoUsd  Float
  costoCop  Float
  trm       Float
  
  createdAt DateTime @default(now())
}
