# Base de datos PostgreSQL (Neon)
DATABASE_URL="postgresql://usuario:password@host/db"

# Secreto para firmar los JWT de sesión
JWT_SECRET="cambia-esto-por-un-secreto-largo"

# API Key de Holded (Configuración → Developers → API Keys → Nueva API Key)
# Se usa para crear automáticamente en Holded los productos nuevos del scanner.
HOLDED_API_KEY=""

# Token secreto para exportar el catálogo a Google Sheets (Apps Script).
# Inventa una cadena larga y usa la misma en el CONFIG del Apps Script.
SHEETS_EXPORT_TOKEN=""
